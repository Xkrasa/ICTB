OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://llm-api.net/v1
# 访问控制：非空时所有 /api/* 请求需携带此 Key（留空则不校验）
API_KEY=
GPT_IMAGE_MODEL=gpt-image-2
GPT_IMAGE_QUALITY=medium
GPT_IMAGE_THINKING=
GPT_IMAGE_SIZE=1024x1024
GPT_IMAGE_TIMEOUT=360

# xhub 同步兜底渠道（OpenAI 兼容；llm-api 429/5xx/401 时自动切换）
# 请填写你申请 key 的实际平台 API 域名，例如 https://api5.xhub.chat/v1
XHUB_API_KEY=sk-your-xhub-key-here
XHUB_BASE_URL=https://api5.xhub.chat/v1
# 同步渠道自动 failover（llm-api → xhub）
GPT_IMAGE_FAILOVER=true

# RunningHub（seedance 图生视频 + RH 工作流生图）
RUNNINGHUB_API_KEY=your-runninghub-key-here
RUNNINGHUB_BASE_URL=https://www.runninghub.cn/openapi/v2
RUNNINGHUB_TIMEOUT=30
# 渠道：official（官方稳定版 4/8/12s）或 low_cost（低价版 10/15s）
SEEDANCE_CHANNEL=official
SEEDANCE_POLL_INTERVAL=5
SEEDANCE_POLL_TIMEOUT=600
# RH 工作流生图轮询（gpt-image-2 thinking 模式常 >10 分钟，默认 900s）
RH_IMAGE_POLL_INTERVAL=5
RH_IMAGE_POLL_TIMEOUT=900
# RH 抠图 AI App（默认 1873566699474571266）
RH_REMOVE_BG_WORKFLOW_ID=1873566699474571266
RH_REMOVE_BG_POLL_INTERVAL=5
RH_REMOVE_BG_POLL_TIMEOUT=600
